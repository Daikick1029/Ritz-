# 本番環境用 .env
# 使用方法: cp .env.production.example .env.production

# サーバー設定
PORT=5000
NODE_ENV=production

# JWT設定
JWT_SECRET=your_very_secure_secret_key_change_this_in_production
JWT_EXPIRE=7d

# データベース設定
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=hidenseek_db

# Socket.io設定
SOCKET_CORS_ORIGIN=https://your-domain.com
